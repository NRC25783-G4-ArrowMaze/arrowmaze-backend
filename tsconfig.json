{
  "compilerOptions": {
    "target": "ES2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "types": ["node", "jest"],
    
    "outDir": "./dist",
    "rootDir": ".", 
    "noEmit": false,
    
    "strict": true,
    "skipLibCheck": true,
    
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*", "tests/**/*"]
}