# Plantilla de config LOCAL de desarrollo.
# Copia este archivo como .env.local (está en .gitignore, nunca se sube):
#   cp .env.local.example .env.local
# El script `npm run dev` lo carga automáticamente si existe.

# ⚠️ Bypass de autenticación SOLO para desarrollo local.
# Con true: cualquier login devuelve un JWT ADMIN y los middlewares de auth/rol
# se omiten, para que forge pueda crear/editar mapas sin una cuenta real.
# NUNCA activar en entornos compartidos ni producción.
LEVELS_SKIP_ROLE_CHECK=true

# El backend exige JWT_SECRET para arrancar (aunque el login esté bypasseado).
# Cualquier valor sirve para desarrollo local.
JWT_SECRET=cambia-esto-secreto-solo-dev

# Descomenta si el puerto 3000 (default) está ocupado en tu máquina.
# Recuerda apuntar el .env.local de forge al mismo puerto.
# PORT=3010

# Descomenta para agregar orígenes CORS extra (reemplaza la lista por defecto).
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost,capacitor://localhost
